<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HLS分片 · 极速播放器（可点击播放）</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            padding: 20px;
            
            /* 背景图设置 */
            background-image: url('poster.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            position: relative;
        }

        /* 半透明遮罩层 */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(3px);
            z-index: 0;
        }

        .player-container {
            position: relative;
            z-index: 1;
            width: min(100%, 1600px);
            margin: 0 auto;
            border-radius: 32px;
            background: rgba(10, 10, 15, 0.8);
            backdrop-filter: blur(10px);
            box-shadow: 0 30px 50px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .video-wrapper {
            position: relative;
            width: 100%;
            aspect-ratio: 16 / 9;
            background-color: rgba(0, 0, 0, 0.2);
            /* 关键：确保视频控件可以穿透点击 */
            pointer-events: none;
        }

        /* 视频元素本身要能接收点击事件 */
        #mainVideo {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: contain;
            background-color: transparent;
            /* 关键：让视频可以接收点击事件 */
            pointer-events: auto;
            /* 确保视频控件在最上层 */
            position: relative;
            z-index: 10;
        }

        /* 移除所有可能遮挡视频控件的元素 */
        .poster-overlay {
            display: none;
        }

        /* 加载指示器 - 但不遮挡控件 */
        .loading-indicator {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(8px);
            padding: 10px 22px;
            border-radius: 60px;
            z-index: 5;  /* 低于视频控件的z-index */
            opacity: 0;
            transition: opacity 0.2s;
            border: 1px solid rgba(255, 255, 255, 0.2);
            pointer-events: none;  /* 让点击穿透 */
        }
        .loading-indicator.show {
            opacity: 1;
        }

        /* 底部渐变遮罩 - 纯装饰，不遮挡点击 */
        .control-gradient {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 90px;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.3) 0%, transparent 100%);
            pointer-events: none;  /* 让点击穿透 */
            z-index: 1;
        }

        .info-bar {
            padding: 16px 24px;
            background: rgba(20, 20, 28, 0.9);
            backdrop-filter: blur(5px);
            color: #e0e3f0;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            position: relative;
            z-index: 20;
        }

        .badge {
            background: rgba(40, 40, 50, 0.8);
            backdrop-filter: blur(4px);
            padding: 6px 14px;
            border-radius: 40px;
            color: #ffffff;
            font-size: 0.85rem;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .badge i {
            color: #5a9eff;
            margin-right: 6px;
        }

        .file-path {
            background: rgba(30, 30, 40, 0.8);
            backdrop-filter: blur(4px);
            padding: 6px 14px;
            border-radius: 40px;
            font-family: monospace;
            font-size: 0.8rem;
            color: #d0d7ff;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .status-badge {
            color: #9effb4;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .status-badge.error {
            color: #ff9e9e;
        }

        .download-btn {
            background: linear-gradient(145deg, #3a7eff, #1a5bef);
            color: white;
            border: none;
            padding: 8px 24px;
            border-radius: 40px;
            font-size: 0.95rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 4px 15px rgba(26, 91, 239, 0.4);
            margin-left: auto;
        }

        .download-btn:hover {
            background: linear-gradient(145deg, #4a8eff, #2a6bff);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(26, 91, 239, 0.6);
        }

        .download-btn.disabled {
            opacity: 0.5;
            pointer-events: none;
        }

        .right-section {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-left: auto;
        }

        .file-size {
            color: #ccd2e6;
            font-size: 0.85rem;
        }

        .page-title {
            position: relative;
            z-index: 1;
            color: white;
            text-align: center;
            margin-bottom: 16px;
            font-size: 1.8rem;
            font-weight: 500;
            text-shadow: 0 2px 10px rgba(0,0,0,0.5);
            display: inline-block;
            padding: 8px 30px;
            border-radius: 60px;
            background: rgba(0,0,0,0.2);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .title-container {
            display: flex;
            justify-content: center;
            margin-bottom: 10px;
        }

        /* Cloudflare 容器 - 居中显示 */
        .cloudflare-container {
            display: flex;
            justify-content: center;
            margin-top: 16px;
            position: relative;
            z-index: 1;
        }

        /* Cloudflare 徽章样式 */
        .cloudflare-badge {
            background: rgba(40, 40, 50, 0.8);
            backdrop-filter: blur(4px);
            padding: 8px 24px;
            border-radius: 60px;
            color: #f6821f;  /* Cloudflare 橙色 */
            font-size: 0.95rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            letter-spacing: 0.3px;
        }

        .cloudflare-badge i {
            font-style: normal;
            font-size: 1.1rem;
        }

        .cloudflare-badge span {
            color: #e0e3f0;
            margin: 0 4px;
        }

        /* 调试辅助 - 显示可点击区域 */
        .click-hint {
            position: absolute;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            color: rgba(255,255,255,0.5);
            font-size: 0.8rem;
            background: rgba(0,0,0,0.3);
            padding: 4px 12px;
            border-radius: 20px;
            pointer-events: none;
            z-index: 15;
        }
    </style>
    <!-- 引入 hls.js 库 -->
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
</head>
<body>
    <div class="title-container">
        <div class="page-title">
            零售机_游戏性能大横评_2026【全网补档】
        </div>
    </div>

    <div class="player-container">
        <div class="video-wrapper">
            <!-- 视频元素：确保可以点击 -->
            <video id="mainVideo" controls playsinline></video>
            
            <!-- 装饰性渐变，不遮挡点击 -->
            <div class="control-gradient"></div>
            
            <!-- 加载指示器，不遮挡点击 -->
            <div class="loading-indicator" id="loadingIndicator">加载分片中...</div>
            
        </div>

        <div class="info-bar">
            <div class="badge"><i>🎬</i> 8.2GB 4K视频</div>
            <div class="badge"><i>📁</i> 分片: /m3u8/</div>
            <div class="file-path">video.m3u8</div>
            <div class="status-badge" id="statusBadge">
                <span>⚡</span> HLS 分片加载
            </div>
            
            <div class="right-section">
                <span class="file-size" id="fileSizeHint">8.2 GB</span>
                <button class="download-btn" id="downloadBtn">
                    <i>⬇️</i> 下载原片
                </button>
            </div>
        </div>
    </div>
    
    <!-- Cloudflare 居中显示 -->
    <div class="cloudflare-container">
        <div class="cloudflare-badge">
            <i>☁️</i> 由 Cloudflare 提供云计算服务支持 <span>|</span> 极速安全
        </div>
    </div>

    <script>
        (function() {
            // 获取元素
            const video = document.getElementById('mainVideo');
            const loadingIndicator = document.getElementById('loadingIndicator');
            const statusBadge = document.getElementById('statusBadge');
            const downloadBtn = document.getElementById('downloadBtn');
            const fileSizeHint = document.getElementById('fileSizeHint');

            // 路径配置
            const PATHS = {
                hls: 'm3u8/video.m3u8',
                fallback: 'video/video.mp4',
            };

            const DOWNLOAD_FILENAME = '极客湾_零售机_游戏性能大横评_2026【4K60Fps】.mp4';

            // 测试点击区域（控制台输出）
            console.log('✅ 播放器已加载，点击视频中央测试播放按钮');

            // 直接测试视频控件是否可点击
            video.addEventListener('click', (e) => {
                console.log('视频被点击，坐标:', e.clientX, e.clientY);
                // 让浏览器原生控件处理点击
            });

            // HLS 加载逻辑
            function loadHLS() {
                if (Hls.isSupported()) {
                    statusBadge.innerHTML = '<span>📦</span> 初始化 HLS...';
                    
                    const hls = new Hls({
                        maxBufferLength: 30,
                        maxMaxBufferLength: 60,
                        startLevel: -1,
                        debug: false,
                    });

                    hls.loadSource(PATHS.hls);
                    hls.attachMedia(video);

                    hls.on(Hls.Events.MANIFEST_PARSED, function() {
                        statusBadge.innerHTML = '<span>✅</span> HLS 分片加载 · 秒开';
                    });

                    hls.on(Hls.Events.BUFFER_LOADING, () => {
                        loadingIndicator.classList.add('show');
                    });

                    hls.on(Hls.Events.BUFFER_APPENDED, () => {
                        loadingIndicator.classList.remove('show');
                    });

                    hls.on(Hls.Events.ERROR, function(event, data) {
                        if (data.fatal) {
                            statusBadge.innerHTML = '<span>⚠️</span> HLS 加载失败，使用原视频';
                            statusBadge.classList.add('error');
                            video.src = PATHS.fallback;
                            video.load();
                            hls.destroy();
                        }
                    });

                } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                    video.src = PATHS.hls;
                    statusBadge.innerHTML = '<span>🍎</span> Safari 原生 HLS';
                } else {
                    video.src = PATHS.fallback;
                    statusBadge.innerHTML = '<span>📼</span> 使用原视频 (MP4)';
                }
            }

            // 启动加载
            if (document.readyState === 'complete') {
                loadHLS();
            } else {
                window.addEventListener('load', loadHLS);
            }

            // 加载状态检测
            setInterval(() => {
                if (video.readyState < 3) {
                    loadingIndicator.classList.add('show');
                } else {
                    loadingIndicator.classList.remove('show');
                }
            }, 500);

            // 下载功能
            function handleDownload() {
                downloadBtn.classList.add('disabled');
                downloadBtn.innerHTML = '<i>⏳</i> 准备下载...';
                
                const link = document.createElement('a');
                link.href = PATHS.fallback;
                link.download = DOWNLOAD_FILENAME;
                link.style.display = 'none';
                
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                
                setTimeout(() => {
                    downloadBtn.classList.remove('disabled');
                    downloadBtn.innerHTML = '<i>⬇️</i> 下载原片';
                }, 1000);
                
                fileSizeHint.innerText = '开始下载 8.2GB 文件...';
                setTimeout(() => {
                    fileSizeHint.innerText = '8.2 GB';
                }, 3000);
            }

            downloadBtn.addEventListener('click', handleDownload);

            document.addEventListener('keydown', (e) => {
                if (e.key === 'd' || e.key === 'D') {
                    if (!e.target.matches('input, textarea')) {
                        e.preventDefault();
                        handleDownload();
                    }
                }
            });

            // 文件检查
            fetch(PATHS.fallback, { method: 'HEAD' })
                .then(response => {
                    if (response.ok) {
                        const size = response.headers.get('content-length');
                        if (size) {
                            const gb = (parseInt(size) / (1024*1024*1024)).toFixed(1);
                            fileSizeHint.innerText = `${gb} GB`;
                        }
                    }
                })
                .catch(() => {});

            console.log('✅ 播放器已就绪 - 播放按钮可点击');
        })();
    </script>
</body>
</html>